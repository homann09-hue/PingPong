DATABASE_URL=postgres://aurora:change-me@localhost:5432/aurora
# At least 32 random bytes; inject from a secrets manager outside local development.
JWT_SECRET=replace-with-a-long-random-development-secret
# Independent workforce token secret; never reuse the player JWT secret.
ADMIN_JWT_SECRET=replace-with-a-separate-long-random-admin-secret
# Protects the internal Prometheus scrape endpoint; minimum 32 random bytes.
METRICS_TOKEN=replace-with-a-long-random-monitoring-token
# Base64-encoded 32-byte AES key used to encrypt push provider tokens at rest.
PUSH_TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
# HTTPS gateway that normalizes APNs, FCM, and Web Push delivery.
PUSH_GATEWAY_URL=https://push-gateway.example.internal/v1/messages
PUSH_GATEWAY_TOKEN=replace-with-a-long-random-gateway-token
PORT=8080
