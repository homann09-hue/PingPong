{
  "name": "@aurora/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../player-web/.env.local src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --no-file-parallelism --hook-timeout=30000",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aurora/slot-engine": "0.1.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^10.1.0",
    "fastify": "^5.4.0",
    "jose": "^6.0.11",
    "pg": "^8.16.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
