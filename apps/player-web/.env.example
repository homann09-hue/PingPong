# Server-only URL of the existing Aurora API. Never expose this as NEXT_PUBLIC_*.
AURORA_API_URL=http://127.0.0.1:8080

# Public Supabase Auth configuration. Never put a service-role key in this app.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
